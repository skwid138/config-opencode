{
    "$schema": "https://opencode.ai/config.json",
    "model": "github-copilot/claude-opus-4.7",
    "agent": {
        "build": {
            "mode": "subagent",
            "hidden": true,
            "description": "Hidden by local config"
        },
        "plan": {
            "mode": "subagent",
            "hidden": true,
            "description": "Hidden by local config"
        }
    },
    "instructions": [
        "instruction/repo-context.md",
        "instruction/codebase-map.md",
        "instruction/orchestration-runtime.md",
        "instruction/script-usage.md"
    ],
    "permission": {
        "external_directory": {
            "/Users/hunter/code/wpromote/*": "allow",
            "/Users/hunter/code/scripts/*": "allow"
        }
    },
    "plugin": [
      "@tarquinen/opencode-dcp@3.1.9"
    ],
    "mcp": {
        "chrome-devtools": {
            "type": "local",
            "command": ["npx", "-y", "chrome-devtools-mcp@0.23.0", "--browserUrl", "http://127.0.0.1:9222"],
            "enabled": true
        },
        "context7": {
            "type": "remote",
            "url": "https://mcp.context7.com/mcp",
            "enabled": true
        },
        "exa": {
            "type": "remote",
            "url": "https://mcp.exa.ai/mcp",
            "enabled": true
        },
        "figma": {
            "type": "remote",
            "url": "http://127.0.0.1:3845/mcp",
            "enabled": true
        }
    }
}
