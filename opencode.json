{
    "$schema": "https://opencode.ai/config.json",
    "model": "github-copilot/claude-opus-4.6",
    "agent": {
        "build": {
            "mode": "subagent",
            "hidden": true,
            "description": "Hidden by local config"
        },
        "plan": {
            "mode": "subagent",
            "hidden": true,
            "description": "Hidden by local config"
        }
    },
    "instructions": [
        "instruction/repo-context.md",
        "instruction/script-usage.md",
        "instruction/agent-defaults.md"
    ],
    "permission": {
        "external_directory": {
            "/Users/hunter/.config/opencode/*": "allow",
            "/Users/hunter/code/dotfiles/*": "allow",
            "/Users/hunter/code/scripts/*": "allow",
            "/Users/hunter/code/wpromote/*": "allow"
        },
        "edit": "ask",
        "write": "ask",
        "bash": {
            "*": "ask"
        }
    },
    "plugin": [
        "@tarquinen/opencode-dcp@3.1.11"
    ],
    "mcp": {
        "chrome-devtools": {
            "type": "local",
            "command": [
                "npx",
                "-y",
                "chrome-devtools-mcp@0.25.0",
                "--browserUrl",
                "http://127.0.0.1:9222"
            ],
            "enabled": true
        },
        "context7": {
            "type": "remote",
            "url": "https://mcp.context7.com/mcp",
            "enabled": true
        },
        "exa": {
            "type": "remote",
            "url": "https://mcp.exa.ai/mcp",
            "enabled": true
        },
        "figma": {
            "type": "remote",
            "url": "http://127.0.0.1:3845/mcp",
            "enabled": true
        }
    }
}