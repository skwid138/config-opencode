{
    "$schema": "https://opencode.ai/config.json",
    "model": "github-copilot/claude-opus-4.6",
    "small_model": "openai/gpt-5-mini",
    "agent": {
        "build": {
            "mode": "subagent",
            "hidden": true,
            "description": "Hidden by local config"
        },
        "plan": {
            "mode": "subagent",
            "hidden": true,
            "description": "Hidden by local config"
        },
        "general": {
            "mode": "subagent",
            "hidden": true,
            "description": "Hidden by local config"
        },
        "compaction": {
            "model": "openai/gpt-5.5"
        }
    },
    "instructions": [
        "instruction/repo-context.md",
        "instruction/script-usage.md",
        "instruction/agent-defaults.md"
    ],
    "permission": {
        "external_directory": {
            "/Users/hunter/.config/opencode/*": "allow",
            "/Users/hunter/code/dotfiles/*": "allow",
            "/Users/hunter/code/scripts/*": "allow",
            "/Users/hunter/code/wpromote/*": "allow"
        },
        "edit": "ask",
        "write": "ask",
        "bash": {
            "*": "ask",
            "bats": "allow",
            "brew info*": "allow",
            "cat *": "allow",
            "diff *": "allow",
            "dirname *": "allow",
            "echo *": "allow",
            "file *": "allow",
            "find *": "allow",
            "gh api *": "allow",
            "gh auth status": "allow",
            "gh issue list*": "allow",
            "gh issue view*": "allow",
            "gh pr checks*": "allow",
            "gh pr diff*": "allow",
            "gh pr list*": "allow",
            "gh pr summary*": "allow",
            "gh pr view*": "allow",
            "gh repo view*": "allow",
            "gh run list*": "allow",
            "gh run view*": "allow",
            "git -C *": "allow",
            "git blame*": "allow",
            "git branch*": "allow",
            "git diff*": "allow",
            "git grep*": "allow",
            "git log*": "allow",
            "git ls-files*": "allow",
            "git remote*": "allow",
            "git rev-parse*": "allow",
            "git show*": "allow",
            "git status*": "allow",
            "grep *": "allow",
            "head *": "allow",
            "jq *": "allow",
            "ls *": "allow",
            "make check*": "allow",
            "make fmt*": "allow",
            "make lint*": "allow",
            "make test*": "allow",
            "npm view*": "allow",
            "printenv*": "allow",
            "printf *": "allow",
            "ps": "allow",
            "ps *": "allow",
            "pwd": "allow",
            "readlink *": "allow",
            "rg *": "allow",
            "sort": "allow",
            "sort *": "allow",
            "tail *": "allow",
            "wc *": "allow",
            "which *": "allow",
            "/Users/hunter/code/scripts/agent/branch-to-ticket.sh*": "allow",
            "/Users/hunter/code/scripts/agent/chrome_mcp.sh*": "allow",
            "/Users/hunter/code/scripts/agent/gh-current-pr.sh*": "allow",
            "/Users/hunter/code/scripts/agent/gh-pr-checks-summary.sh*": "allow",
            "/Users/hunter/code/scripts/agent/gh-pr-comments.sh*": "allow",
            "/Users/hunter/code/scripts/agent/jira-fetch-ticket.sh*": "allow",
            "/Users/hunter/code/scripts/agent/opencode-deps-check.sh*": "allow",
            "/Users/hunter/code/scripts/agent/scripts-doctor.sh*": "allow",
            "/Users/hunter/code/scripts/agent/sonar-pr-issues.sh*": "allow",
            "/Users/hunter/code/wpromote/scripts/agent/auto-ticket-context.sh*": "allow",
            "/Users/hunter/code/wpromote/scripts/agent/gcp-project-map.sh*": "allow",
            "/Users/hunter/code/wpromote/scripts/agent/gke-logs.sh*": "allow",
            "/Users/hunter/code/wpromote/scripts/agent/jira-find-qa-subtask.sh*": "allow",
            "/Users/hunter/code/wpromote/scripts/agent/jira-qa-render.sh*": "allow",
            "git push * --force*": "deny",
            "git push * -f*": "deny",
            "git push --force*": "deny",
            "git push -f*": "deny",
            "rm *": "deny",
            "sudo *": "deny"
        }
    },
    "plugin": [
        "@tarquinen/opencode-dcp@3.1.11"
    ],
    "watcher": {
        "ignore": [
            "node_modules",
            ".git",
            "dist",
            "build",
            ".next",
            "coverage",
            "logs",
            ".stryker-tmp",
            "storybook-static",
            ".venv",
            "__pycache__"
        ]
    },
    "mcp": {
        "chrome-devtools": {
            "type": "local",
            "command": [
                "npx",
                "-y",
                "chrome-devtools-mcp@0.25.0",
                "--browserUrl",
                "http://127.0.0.1:9222"
            ],
            "enabled": true
        },
        "context7": {
            "type": "remote",
            "url": "https://mcp.context7.com/mcp",
            "enabled": true
        },
        "exa": {
            "type": "remote",
            "url": "https://mcp.exa.ai/mcp",
            "enabled": true
        },
        "figma": {
            "type": "remote",
            "url": "http://127.0.0.1:3845/mcp",
            "enabled": true
        }
    }
}
