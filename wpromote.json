{
    "$schema": "./schemas/wpromote.schema.json",
    "agentNames": "lotr",
    "installMethod": "link",
    "disable": [
        "agent:orchestrator",
        "agent:deepwork",
        "agent:explorer",
        "agent:implementer",
        "agent:planner",
        "agent:researcher",
        "agent:architect",
        "agent:analyst",
        "agent:tdd",
        "skill:example",
        "mcp:chrome-devtools",
        "mcp:context7",
        "mcp:exa"
    ],
    "orchestration": {
        "providerMode": "copilot",
        "features": {
            "delegation": true,
            "diagnostics": true,
            "vision": true,
            "continuousLoop": true,
            "selfHealing": true
        },
        "limits": {
            "maxConcurrent": 3,
            "maxRetries": 2,
            "maxIterations": 25
        },
        "runtimeFallback": {
            "enabled": true,
            "providerOrder": [
                "copilot",
                "native"
            ]
        },
        "recovery": {
            "autoResumeOnStart": true
        }
    }
}
