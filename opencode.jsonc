{
    "$schema": "https://opencode.ai/config.json",
    "model": "github-copilot/claude-opus-4.8",
    "small_model": "openai/gpt-5.4-mini",
    "agent": {
        "build": {
            "mode": "subagent",
            "hidden": true,
            "description": "Hidden by local config"
        },
        "plan": {
            "mode": "subagent",
            "hidden": true,
            "description": "Hidden by local config"
        },
        "general": {
            "mode": "subagent",
            "hidden": true,
            "description": "Hidden by local config"
        },
        "compaction": {
            "model": "openai/gpt-5.5"
        }
    },
    "instructions": [
        "instruction/repo-context.md",
        "instruction/script-usage.md",
        "instruction/agent-defaults.md"
    ],
    "permission": {
        "external_directory": {
            "*": "ask",
            "/Users/hunter/.config/opencode/*": "allow",
            "/Users/hunter/code/*": "allow",
            "/tmp/*": "allow",
            "/var/folders/q1/zwn7qv6n4xd9wx2hvrz6cm5m0000gn/T/opencode/*": "allow",
            "/Users/hunter/.nvm/*": "allow",
            "/Users/hunter/.cache/*": "allow",
            "/Users/hunter/.local/*": "allow",
            "/Users/hunter/Library/Caches/opencode/*": "allow",
            "/Users/hunter/go/*": "allow",
            "/opt/homebrew/*": "allow",
            "/usr/local/*": "allow",
            "*wpromute*": "deny"
        },
        "edit": "ask",
        "write": "ask",
        "bash": {
            "*": "ask",
            "bats": "allow",
            "brew info*": "allow",
            "cat *": "allow",
            "diff *": "allow",
            "dirname *": "allow",
            "echo *": "allow",
            "file *": "allow",
            "find *": "allow",
            "gh api *": "allow",
            "gh auth status": "allow",
            "gh issue list*": "allow",
            "gh issue view*": "allow",
            "gh pr checks*": "allow",
            "gh pr diff*": "allow",
            "gh pr list*": "allow",
            "gh pr summary*": "allow",
            "gh pr view*": "allow",
            "gh repo view*": "allow",
            "gh run list*": "allow",
            "gh run view*": "allow",
            "git -C *": "allow",
            "git blame*": "allow",
            "git branch*": "allow",
            "git diff*": "allow",
            "git grep*": "allow",
            "git log*": "allow",
            "git ls-files*": "allow",
            "git remote*": "allow",
            "git rev-parse*": "allow",
            "git show*": "allow",
            "git status*": "allow",
            "grep *": "allow",
            "head *": "allow",
            "jq *": "allow",
            "ls *": "allow",
            "make check*": "allow",
            "make fmt*": "allow",
            "make lint*": "allow",
            "make test*": "allow",
            "npm test*": "allow",
            "npm view*": "allow",
            "npx tsc*": "allow",
            "printenv*": "allow",
            "printf *": "allow",
            "ps": "allow",
            "ps *": "allow",
            "pwd": "allow",
            "python3 -": "allow",
            "python3 - *": "allow",
            "python3 -c *": "allow",
            "readlink *": "allow",
            "rg *": "allow",
            "sed *": "allow",
            "sort": "allow",
            "sort *": "allow",
            "sqlite3 *": "allow",
            "tail *": "allow",
            "wc *": "allow",
            "which *": "allow",
            "/Users/hunter/code/scripts/agent/branch-to-ticket.sh*": "allow",
            "/Users/hunter/code/scripts/agent/chrome_mcp.sh*": "allow",
            "/Users/hunter/code/scripts/agent/gh-current-pr.sh*": "allow",
            "/Users/hunter/code/scripts/agent/gh-pr-checks-summary.sh*": "allow",
            "/Users/hunter/code/scripts/agent/gh-pr-comments.sh*": "allow",
            "/Users/hunter/code/scripts/agent/jira-fetch-ticket.sh*": "allow",
            "/Users/hunter/code/scripts/agent/opencode-deps-check.sh*": "allow",
            "/Users/hunter/code/scripts/agent/scripts-doctor.sh*": "allow",
            "/Users/hunter/code/scripts/agent/sonar-pr-issues.sh*": "allow",
            "/Users/hunter/code/wpromote/scripts/agent/auto-ticket-context.sh*": "allow",
            "/Users/hunter/code/wpromote/scripts/agent/gcp-project-map.sh*": "allow",
            "/Users/hunter/code/wpromote/scripts/agent/gke-logs.sh*": "allow",
            "/Users/hunter/code/wpromote/scripts/agent/jira-find-qa-subtask.sh*": "allow",
            "/Users/hunter/code/wpromote/scripts/agent/jira-qa-render.sh*": "allow",
            "acli jira *": "allow",
            "bats *": "allow",
            "brew --prefix*": "allow",
            "brew list*": "allow",
            "npm info*": "allow",
            "npm root*": "allow",
            "opencode --version": "allow",
            "realpath *": "allow",
            "basename *": "allow",
            "true": "allow",
            "gh search *": "allow",
            "strings *": "allow",
            "stat *": "allow",
            "type *": "allow",
            "test *": "allow",
            "~/code/scripts/agent/*": "allow",
            "~/code/wpromote/scripts/agent/*": "allow",
            "command -v *": "allow",
            "log show*": "allow",
            "log stats*": "allow",
            "log help*": "allow",
            "/opt/homebrew/bin/opencode --help": "allow",
            "/opt/homebrew/bin/opencode --version": "allow",
            "/opt/homebrew/bin/opencode version": "allow",
            "git stash list*": "allow",
            "git stash show*": "allow",
            "/Users/hunter/code/scripts/agent/permission-audit.sh*": "allow",
            "/Users/hunter/code/scripts/agent/auto-ticket-context.sh*": "deny",
            "git push * --force*": "deny",
            "git push * -f*": "deny",
            "git push --force*": "deny",
            "git push -f*": "deny",
            "rm *": "deny",
            "sed -i *": "deny",
            "sed -i*": "deny",
            "sudo *": "deny",
            "*wpromute*": "deny"
        }
    },
    "plugin": [
        "@tarquinen/opencode-dcp@3.1.12",
        "./plugins/src/vision-tool.ts",
        [
            "@skwid138/opencode-council@0.10.0",
            {
                "council": {
                    "reviewer": "saruman",
                    "debug": true,
                    "models": [
                        {
                            "providerID": "github-copilot",
                            "modelID": "claude-opus-4.6"
                        },
                        {
                            "providerID": "openai",
                            "modelID": "gpt-5.5"
                        },
                        // {
                        //     "providerID": "github-copilot",
                        //     "modelID": "gemini-3.1-pro-preview"
                        // },
                        {
                            "providerID": "github-copilot",
                            "modelID": "gemini-3.5-flash"
                        },
                        {
                            "providerID": "github-copilot",
                            "modelID": "gpt-5.3-codex"
                        },
                        // {
                        //     "providerID": "opencode-go",
                        //     "modelID": "mimo-v2.5"
                        // },
                        // {
                        //     "providerID": "opencode-go",
                        //     "modelID": "deepseek-v4-flash"
                        // },
                        // {
                        //     "providerID": "opencode-go",
                        //     "modelID": "deepseek-v4-pro"
                        // },
                        // {
                        //     "providerID": "opencode-go",
                        //     "modelID": "kimi-k2.6"
                        // },
                        // {
                        //     "providerID": "opencode-go",
                        //     "modelID": "qwen3.7-max"
                        // }
                    ],
                    "aggregator_model": {
                        "providerID": "openai",
                        "modelID": "gpt-5.5-fast"
                    },
                    "quorum": 4,
                    "timeouts": {
                        "aggregator_ms": 120000
                    }
                }
            }
        ]
    ],
    "watcher": {
        "ignore": [
            "node_modules",
            ".git",
            "dist",
            "build",
            ".next",
            "coverage",
            "logs",
            ".stryker-tmp",
            "storybook-static",
            ".venv",
            "__pycache__"
        ]
    },
    "mcp": {
        "chrome-devtools": {
            "type": "local",
            "command": [
                "npx",
                "-y",
                "chrome-devtools-mcp@1.1.1",
                "--browserUrl",
                "http://127.0.0.1:9222"
            ],
            "enabled": true
        },
        "context7": {
            "type": "remote",
            "url": "https://mcp.context7.com/mcp",
            "enabled": true
        },
        "exa": {
            "type": "remote",
            "url": "https://mcp.exa.ai/mcp",
            "enabled": true
        },
        "figma": {
            "type": "remote",
            "url": "http://127.0.0.1:3845/mcp",
            "enabled": true
        }
    }
}
